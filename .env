# ===================================================
# プラットフォーム設定（Platform Configuration）
# ===================================================
# このセクションを編集してください。
# このファイルはリポジトリにコミットされます（シークレット不可）。
# シークレット（APIキー等）は .env.local に記入してください。
# GitHubのWeb UIから直接このファイルを編集できます。
# ===================================================

# ── プラットフォーム情報 ─────────────────────────────────────────────────────
# サービス名（ブラウザタブ・メール・全ページに表示されます）
PLATFORM_NAME=Community Merch Platform

# 短い説明文（トップページに表示）
PLATFORM_TAGLINE=Fundraise with custom merch

# メインカラー（#から始まる6桁の色コード）
PLATFORM_PRIMARY_COLOR=#2E4057

# アクセントカラー（ボタン等に使用）
PLATFORM_ACCENT_COLOR=#378ADD

# セットアップを完了する人のメールアドレス（Platform Adminになる人）
PLATFORM_ADMIN_EMAIL=your-email@example.com

# ── URL設定 ──────────────────────────────────────────────────────────────────
# Vercelのデプロイ後に発行されるURL（または独自ドメイン）
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
BETTER_AUTH_URL=https://your-app.vercel.app

# ── メール送信元 ─────────────────────────────────────────────────────────────
# 注文確認メール等の送信元アドレス
EMAIL_FROM=noreply@your-domain.com

# ── Cloudflare R2（公開設定のみ・シークレットは .env.local へ）─────────────
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Stripe（公開鍵のみ・シークレットは .env.local へ）──────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Google OAuth（クライアントIDのみ・シークレットは .env.local へ）─────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ===================================================
# 開発ツール設定（変更不要）
# Claude Code / MCP サーバー用の設定です
# ===================================================

NODE_ENV=development
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TIMESTAMP=true

MCP_SERVER_TIMEOUT=30000
MCP_MAX_RETRIES=3
MCP_CONNECTION_TIMEOUT=10000

CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
ENABLE_PERFORMANCE_MONITORING=false

CORS_ENABLED=true
RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS_PER_MINUTE=60

ENABLE_HOT_RELOAD=true
ENABLE_SOURCE_MAPS=true
ENABLE_DEBUG_MODE=false
ENABLE_EXPERIMENTAL_FEATURES=false

ENABLE_VEO3_VIDEO_GENERATION=true
ENABLE_MULMOCAST_SLIDES=true
ENABLE_PLAYWRIGHT_AUTOMATION=true

VEO3_OUTPUT_DIR=/tmp/veo3_videos
VEO3_DEFAULT_RESOLUTION=720p
VEO3_DEFAULT_DURATION=8

FILESYSTEM_MAX_ALLOWED_PATHS=2
